; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="trashfish"
config/version="0.2.0.1"
run/main_scene="res://scenes/main/game_master.tscn"
config/use_custom_user_dir=true
config/custom_user_dir_name="trashfish"
config/features=PackedStringArray("4.4", "Forward Plus")
boot_splash/bg_color=Color(0.0430392, 0.0430392, 0.0430391, 1)
boot_splash/fullsize=false
boot_splash/image="res://art/misc/splash_screen.png"
config/icon="res://art/misc/desktop_icon.png"
config/windows_native_icon="res://art/misc/icon.ico"

[audio]

buses/default_bus_layout="res://scenes/misc/default_bus_layout.tres"

[autoload]

save_master="*res://scripts/main/save_master.gd"
online_master="*res://scripts/main/online_master.gd"
global="*res://scripts/misc/global_variables.gd"
AntialiasedLine2DTexture="*res://addons/antialiased_line2d/texture.gd"
Cursor="*res://addons/awesome_custom_cursor/Autoloads/Cursor.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"
window/stretch/aspect="ignore"

[editor]

naming/node_name_num_separator=2
naming/node_name_casing=2
naming/script_name_casing=2

[editor_plugins]

enabled=PackedStringArray("res://addons/GenerateAnimationPlayerFrameTracks/plugin.cfg", "res://addons/antialiased_line2d/plugin.cfg", "res://addons/awesome_custom_cursor/plugin.cfg", "res://addons/cameraregion2d/plugin.cfg", "res://addons/gdmaim/plugin.cfg", "res://addons/minimize_html_build/plugin.cfg", "res://addons/simpleboards_plugin/plugin.cfg")

[global_group]

player="player group"
attack=""
drop=""
seaweed="seaweed"
baby_fish=""
controls="use this for the control labels so they can be set properly"
orca="orcane"

